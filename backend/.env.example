PORT=5000
# Use PORT=5001 locally if your CRA frontend proxies to http://localhost:5001 (see frontend/package.json).

# AI assistant (Google Gemini). Create a key in Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default in code is gemini-2.5-flash. If you see "free_tier ... limit: 0", link billing on the GCP project
# or try: gemini-1.5-flash, gemini-2.0-flash, gemini-2.5-flash-lite (see https://ai.google.dev/gemini-api/docs/models )
GEMINI_MODEL=gemini-2.5-flash

DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=your_password_here
